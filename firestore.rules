rules_version = '2';

// StadiumIQ writes incidents only through the trusted backend using the
// Firebase Admin SDK, which bypasses these rules. Direct client access is
// therefore denied by default — a secure-by-default posture.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
