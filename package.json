{
  "name": "stadiumiq",
  "version": "1.0.0",
  "description": "StadiumIQ — a GenAI, role-aware match-day assistant for the FIFA World Cup 2026 that helps fans, staff, volunteers and organizers with navigation, crowd, accessibility, transport, sustainability and real-time operational decisions.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "node --test --experimental-test-coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{api,public,src,test}/**/*.{js,json,css,html}\" \"*.{js,json}\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"{api,public,src,test}/**/*.{js,json,css,html}\" \"*.{js,json}\" \".github/**/*.yml\""
  },
  "keywords": [
    "fifa-world-cup-2026",
    "gemini",
    "generative-ai",
    "smart-stadium",
    "accessibility",
    "assistant"
  ],
  "author": "StadiumIQ Team",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.30.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.9.5"
  }
}
