# ---------------------------------------------------------------------------
# StadiumIQ environment configuration
# Copy this file to ".env" and fill in your values:  cp .env.example .env
# The ".env" file is gitignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# Google Gemini API key from https://aistudio.google.com/apikey
# If this is left blank, StadiumIQ automatically runs in OFFLINE mode using its
# built-in deterministic reasoning engine — so the app still works without a key.
GEMINI_API_KEY=

# Gemini model to use. Defaults to a free-tier-eligible model.
# Alternatives: gemini-3-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# HTTP port for the server.
PORT=3000

# Node environment: "development" or "production".
NODE_ENV=development

# Comma-separated list of allowed CORS origins. "*" allows any origin.
CORS_ORIGIN=*

# Rate limiting: max requests per IP within the window (minutes).
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=60
