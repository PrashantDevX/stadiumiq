# ---------------------------------------------------------------------------
# StadiumIQ environment configuration
# Copy this file to ".env" and fill in your values:  cp .env.example .env
# The ".env" file is gitignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# Google Gemini API key from https://aistudio.google.com/apikey
# If this is left blank, StadiumIQ automatically runs in OFFLINE mode using its
# built-in deterministic reasoning engine — so the app still works without a key.
GEMINI_API_KEY=

# Gemini model to use. Defaults to a free-tier-eligible model.
# Alternatives: gemini-3-flash, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# HTTP port for the server.
PORT=3000

# Node environment: "development" or "production".
NODE_ENV=development

# Comma-separated list of allowed CORS origins. "*" allows any origin.
CORS_ORIGIN=*

# Rate limiting: max requests per IP within the window (minutes).
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=60

# ---------------------------------------------------------------------------
# Google Cloud / Firebase (all OPTIONAL — the app runs fully without them)
# ---------------------------------------------------------------------------

# Your Firebase / Google Cloud project id. Setting this enables Cloud Firestore
# persistence for incidents. Leave blank to use the in-memory store.
FIREBASE_PROJECT_ID=

# Firestore collection name for logged incidents.
FIRESTORE_INCIDENTS_COLLECTION=incidents

# LOCAL ONLY: absolute path to a service-account JSON key for Firestore access.
# NOT needed on Cloud Run (Application Default Credentials are automatic).
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
